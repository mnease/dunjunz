# Preferred: NeaseMedia Resend (Vercel → Project → Environment Variables)
#
# In Vercel UI:
#   Name  = RESEND_API_KEY          ← only letters/underscores (NO email here)
#   Value = re_xxxxxxxx             ← paste the secret/key/email HERE
#
RESEND_API_KEY=re_xxxxxxxx
# Optional — code defaults to: DUNJUNZ Feedback <support@neasemedia.com>
# RESEND_FROM=DUNJUNZ Feedback <support@neasemedia.com>
# FEEDBACK_TO=support@neasemedia.com

# Fallback only: classic SMTP (unused when RESEND_API_KEY is set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@neasemedia.com
# SMTP_SECURE=false
