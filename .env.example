# --- Resend (feedback + magic links) ---
RESEND_API_KEY=re_xxxxxxxx
# Optional From (defaults to support@neasemedia.com)
# RESEND_FROM=DUNJUNZ <support@neasemedia.com>
# AUTH_FROM=DUNJUNZ <support@neasemedia.com>
FEEDBACK_TO=support@neasemedia.com

# --- Auth / cloud saves (Neon Postgres) ---
# Create a Neon project, run sql/001_auth_slots.sql, paste connection string:
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
# Public site URL (magic link destination) — production:
AUTH_BASE_URL=https://dunjunz.vercel.app
