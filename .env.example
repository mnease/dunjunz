# Preferred: NeaseMedia Resend (Vercel → Project → Environment Variables)
RESEND_API_KEY=re_xxxxxxxx
# Must use a domain verified in Resend (not a random Gmail)
RESEND_FROM=DUNJUNZ Feedback <feedback@your-verified-domain.com>
FEEDBACK_TO=support@neasemedia.com

# Fallback only: classic SMTP (unused when RESEND_API_KEY is set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@neasemedia.com
# SMTP_SECURE=false
