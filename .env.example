# SMTP — required for /api/feedback (set in Vercel → Project → Settings → Env)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
# Optional: true/1 for port 465 implicit TLS
# SMTP_SECURE=false
# From address (defaults to SMTP_USER)
# SMTP_FROM=noreply@neasemedia.com
# Destination inbox (default)
FEEDBACK_TO=support@neasemedia.com
# VERBOSE_SMTP=1
